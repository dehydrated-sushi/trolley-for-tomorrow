# Flask
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-secret

# Database (PostgreSQL via Neon)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=30

# CORS
CORS_ORIGINS=http://localhost:3000

# Pixabay — recipe hero photos on the Meals page (optional).
# Get a free key at https://pixabay.com/api/docs/ (account required).
# If unset, the /api/meals/recipe-image/:id endpoint 404s on every call
# and the frontend falls back to the gradient + category-icon hero.
PIXABAY_API_KEY=
